# SERVELECT WORK OS / EMP — Environment Template
# v0.6 remains deployment-safe: mock data and demo auth are the defaults.

# mock = server-side mock repository; prisma = real PostgreSQL/Prisma repository
SERVELECT_DATA_PROVIDER=mock

# Required only when SERVELECT_DATA_PROVIDER=prisma
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/servelect_work_os?sslmode=require"

# Used by POST /api/v1/db/seed after Prisma is active
SERVELECT_SEED_TOKEN="change-me-long-random-token"

# v0.6 Auth / RBAC foundation
# If empty, any demo user can log in without password.
SERVELECT_DEMO_PASSWORD=""

# If true, write API permissions require an authenticated cookie session or x-servelect headers.
# Default false keeps the public Vercel demo usable.
SERVELECT_REQUIRE_AUTH=false

# Future production auth/JWT foundation
SERVELECT_JWT_SECRET="change-me-before-production"
SERVELECT_APP_URL="http://localhost:3000"
