# SERVELECT WORK OS / EMP — v0.4 Backend Foundation
# Current v0.4 deploy works without these variables using mock API repositories.

NEXT_PUBLIC_APP_NAME="SERVELECT WORK OS"
NEXT_PUBLIC_APP_ENV="development"

# Enable in v0.5+ when PostgreSQL/Prisma is activated.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/servelect_work_os?schema=public"

# Future Auth/RBAC secrets.
AUTH_SECRET="change-me"
JWT_SECRET="change-me"

# Future Redis / live updates.
REDIS_URL="redis://localhost:6379"
