{
  "name": "servelect-work-os",
  "private": true,
  "version": "9.8.0",
  "description": "SERVELECT EMP / WORK OS - task-first enterprise platform for PV projects, operations, IoT, CRM, maintenance and HR.",
  "packageManager": "pnpm@11.5.1",
  "scripts": {
    "dev": "pnpm --filter @servelect/web dev",
    "dev:web": "pnpm --filter @servelect/web dev",
    "dev:mobile": "pnpm --filter @servelect/mobile start",
    "build": "pnpm --filter @servelect/web build",
    "lint": "pnpm --filter @servelect/web lint",
    "typecheck": "pnpm --filter @servelect/web typecheck",
    "goodday:parity:test": "powershell -ExecutionPolicy Bypass -File scripts/work-os-goodday-parity-functional-test.ps1",
    "audit:taskuri:screenshots": "node scripts/audit-taskuri-screenshots.mjs",
    "screenshot:audit": "node scripts/audit-taskuri-screenshots.mjs",
    "v67:global:smoke": "pwsh -ExecutionPolicy Bypass -File scripts/work-os-v670-global-command-functional-test.ps1",
    "v67:global:screenshots": "node scripts/audit-v67-global-routes.mjs"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "typescript": "^5.6.3",
    "playwright": "^1.49.0"
  }
}
