function showImportModal(): void {
  const panel = createModal("Import — mock interactiv cu preview și validare");
  const input = document.createElement("input");
  input.type = "file";
  input.accept = ".csv,.txt,.xlsx";
  const preview = document.createElement("pre");
  preview.style.minHeight = "90px";
  preview.style.background = "#f8fafc";
  preview.style.border = "1px solid #e2e8f0";
  preview.style.borderRadius = "10px";
  preview.style.padding = "10px";
  preview.textContent = "Alege fișier CSV/TXT. Pentru XLSX se înregistrează mock import și se cere backend parser în v18.";
  input.addEventListener("change", () => {
    const file = input.files?.[0];
    if (!file) return;
    if (file.name.endsWith(".xlsx")) {
      preview.textContent = `Fișier detectat: ${file.name}\nTip: XLSX\nStatus: mock mapping, parser real în v18.`;
      return;
    }
    const reader = new FileReader();
    reader.onload = () => {
      const text = String(reader.result ?? "");
      const firstLines = text.split(/\r?\n/).slice(0, 5).join("\n");
      preview.textContent = `Fișier detectat: ${file.name}\nColoane/preview:\n${firstLines}`;
    };
    reader.readAsText(file);
  });
  const runImport = document.createElement("button");
  runImport.type = "button";
  runImport.textContent = "Import preview data";
  runImport.style.marginTop = "12px";
  runImport.style.padding = "10px 14px";
  runImport.style.borderRadius = "10px";
  runImport.style.background = "#00843D";
  runImport.style.color = "#fff";
  runImport.style.border = "0";
  runImport.addEventListener("click", () => {
    const state = mutateState((draft) => {
      const task: V171Task = {
        id: makeId("import-task"),
        title: "Task importat din fișier / mapping mock",
        project: "Import / Operațiuni",
        department: "Administrativ",
        assignee: "Ioana Marinescu",
        status: "Planificat",
        priority: "Medium",
        dueDate: new Date(Date.now() + 86400000 * 7).toISOString().slice(0, 10),
        estimateHours: 2,
        trackedHours: 0,
        comments: 0,
        checklist: ["Validare coloane", "Mapping câmpuri"],
        dependencies: [],
        attachments: input.files?.[0]?.name ? [input.files[0].name] : [],
        createdAt: nowIso(),
        updatedAt: nowIso(),
      };
      draft.tasks.unshift(task);
      notify(draft, "Import finalizat: 1 task creat", "import", task.id);
      addActivity(draft, "Import mock-interactive: preview + 1 task creat/persistat.");
    });
    clearModal();
    toast(`Import rulat. Total taskuri: ${state.tasks.length}.`);
  });
  panel.append(input, preview, runImport);
}

function exportCsv(): void {
  const state = loadState();
  const rows = [["id", "title", "project", "assignee", "status", "priority", "dueDate", "estimateHours", "trackedHours"], ...state.tasks.map((task) => [task.id, task.title, task.project, task.assignee, task.status, task.priority, task.dueDate, String(task.estimateHours), String(task.trackedHours)])];
  const csv = rows.map((row) => row.map((cell) => `"${cell.replace(/"/g, '""')}"`).join(",")).join("\n");
  const blob = new Blob([csv], { type: "text/csv;charset=utf-8" });
  const url = URL.createObjectURL(blob);
  const link = document.createElement("a");
  link.href = url;
  link.download = "servelect-work-os-taskuri-v171-export.csv";
  link.click();
  URL.revokeObjectURL(url);
  mutateState((draft) => addActivity(draft, "Export CSV generat pentru taskuri."));
  toast("Export CSV generat.");
}

function saveView(): void {
  const inputs = Array.from(document.querySelectorAll("input, select")) as Array<HTMLInputElement | HTMLSelectElement>;
  const query = inputs.map((input) => `${input.getAttribute("aria-label") ?? input.name ?? input.placeholder ?? "field"}:${input.value}`).join(" | ");
  const state = mutateState((draft) => {
    const view: V171SavedView = {
      id: makeId("view"),
      title: `Saved view ${routeSection()} ${draft.savedViews.length + 1}`,
      path: getRoute(),
      query,
      density: "Dense",
      statusFilter: query.includes("Review") ? "Review" : "All",
      assigneeFilter: query.includes("Vlad") ? "Vlad" : "All",
      createdAt: nowIso(),
    };
    draft.savedViews.unshift(view);
    notify(draft, `Saved view creat: ${view.title}`, "view", view.id);
    addActivity(draft, `Saved View persistat: ${view.title}`);
  });
  toast(`Saved View persistat. Total: ${state.savedViews.length}.`);
}

function resetFilters(): void {
  const inputs = Array.from(document.querySelectorAll("input, select")) as Array<HTMLInputElement | HTMLSelectElement>;
  inputs.forEach((input) => {
    if (input instanceof HTMLInputElement && input.type !== "file") input.value = "";
    if (input instanceof HTMLSelectElement) input.selectedIndex = 0;
    input.dispatchEvent(new Event("input", { bubbles: true }));
    input.dispatchEvent(new Event("change", { bubbles: true }));
  });
  mutateState((draft) => addActivity(draft, `Filtre resetate pe ${getRoute()}.`));
  toast("Filtre resetate cu feedback și activity log.");
}

function addComment(): void {
  const textareas = Array.from(document.querySelectorAll("textarea")) as HTMLTextAreaElement[];
  const text = textareas.find((area) => area.value.trim())?.value.trim() || "Comentariu adăugat din drawer.";
  mutateState((draft) => {
    const task = draft.tasks[0];
    if (task) {
      task.comments += 1;
      task.updatedAt = nowIso();
      addActivity(draft, `Comentariu pe ${task.title}: ${text}`);
      notify(draft, `Comentariu nou: ${task.title}`, "task", task.id);
    }
  });
  toast("Comentariu salvat, count actualizat și activity log generat.");
}

function addChecklist(): void {
  mutateState((draft) => {
    const task = draft.tasks[0];
    if (task) {
      task.checklist.push(`Checklist item ${task.checklist.length + 1}`);
      task.updatedAt = nowIso();
      addActivity(draft, `Checklist adăugat pe ${task.title}.`);
    }
  });
  toast("Checklist adăugat și persistat.");
}

function addDependency(): void {
  mutateState((draft) => {
    const task = draft.tasks[0];
    const dependency = draft.tasks[1]?.id ?? "manual-dependency";
    if (task && !task.dependencies.includes(dependency)) {
      task.dependencies.push(dependency);
      task.updatedAt = nowIso();
      addActivity(draft, `Dependency adăugat pe ${task.title}.`);
    }
  });
  toast("Dependency adăugat și persistat.");
}

function attachFile(): void {
  mutateState((draft) => {
    const task = draft.tasks[0];
    if (task) {
      task.attachments.push(`mock-file-${task.attachments.length + 1}.pdf`);
      task.updatedAt = nowIso();
      addActivity(draft, `Mock attachment adăugat pe ${task.title}.`);
    }
  });
  toast("Fișier mock atașat și persistat.");
}

function startTimer(): void {
  const state = mutateState((draft) => {
    const task = draft.tasks[0];
    if (!task) return;
    if (draft.activeTimerTaskId) return;
    draft.activeTimerTaskId = task.id;
    draft.timeEntries.unshift({ id: makeId("time"), taskId: task.id, startedAt: nowIso() });
    addActivity(draft, `Timer pornit pentru ${task.title}.`);
  });
  toast(state.activeTimerTaskId ? "Timer pornit." : "Timer deja pornit.", state.activeTimerTaskId ? "success" : "info");
}

function stopTimer(): void {
  mutateState((draft) => {
    const activeId = draft.activeTimerTaskId;
    if (!activeId) return;
    const entry = draft.timeEntries.find((item) => item.taskId === activeId && !item.stoppedAt);
    const task = draft.tasks.find((item) => item.id === activeId);
    if (entry && task) {
      entry.stoppedAt = nowIso();
      entry.hours = 0.25;
      task.trackedHours = Number((task.trackedHours + 0.25).toFixed(2));
      task.updatedAt = nowIso();
      addActivity(draft, `Timer oprit pentru ${task.title}; +0.25h tracked.`);
    }
    draft.activeTimerTaskId = undefined;
  });
  toast("Timer oprit, time entry creat și workload actualizat.");
}

function markRead(all: boolean): void {
  const state = mutateState((draft) => {
    if (all) {
      draft.notifications.forEach((note) => { note.read = true; });
      addActivity(draft, "Toate notificările au fost marcate ca citite.");
    } else {
      const note = draft.notifications.find((item) => !item.read);
      if (note) note.read = true;
      addActivity(draft, "Notificare marcată ca citită.");
    }
  });
  const unread = state.notifications.filter((note) => !note.read).length;
  toast(`Notificări actualizate. Unread: ${unread}.`);
}

function openRelatedEntity(): void {
  const state = loadState();
  const note = state.notifications.find((item) => !item.read) ?? state.notifications[0];
  if (!note) {
    toast("Nu există notificări de deschis.", "info");
    return;
  }
  window.localStorage.setItem("servelect.workos.v171.activeEntity", JSON.stringify(note));
  toast(`Entitate deschisă: ${note.title}`);
  renderSummary(state);
}

function approveReject(approved: boolean): void {
  if (!approved) {
    const reason = window.prompt("Motiv reject obligatoriu:");
    if (!reason?.trim()) {
      toast("Reject anulat: motiv obligatoriu.", "error");
      return;
    }
    mutateState((draft) => {
      const approval = draft.approvals.find((item) => item.status === "Pending");
      if (approval) {
        approval.status = "Rejected";
        approval.reason = reason.trim();
        approval.updatedAt = nowIso();
        addActivity(draft, `Approval respins: ${approval.title}. Motiv: ${reason.trim()}`);
      }
    });
    toast("Approval respins cu motiv și activity log.");
    return;
  }
  mutateState((draft) => {
    const approval = draft.approvals.find((item) => item.status === "Pending");
    if (approval) {
      approval.status = "Approved";
      approval.updatedAt = nowIso();
      addActivity(draft, `Approval acceptat: ${approval.title}.`);
    }
  });
  toast("Approval acceptat și activity log generat.");
}

function bulkAction(): void {
  mutateState((draft) => {
    draft.tasks.slice(0, 2).forEach((task) => {
      task.status = "Review";
      task.updatedAt = nowIso();
    });
    addActivity(draft, "Bulk action: primele 2 taskuri mutate în Review.");
  });
  toast("Bulk action aplicat și persistat.");
}

function cycleRole(): void {
  const order: V171Role[] = ["Viewer", "Member", "Manager", "Super Admin"];
  const state = mutateState((draft) => {
    const nextIndex = (order.indexOf(draft.role) + 1) % order.length;
    draft.role = order[nextIndex];
    addActivity(draft, `Role switcher: ${draft.role}.`);
  });
  toast(`Rol activ: ${state.role}. RBAC local actualizat.`);
}

function normalizeLabel(text: string): string {
  return text.replace(/\s+/g, " ").trim().toLowerCase();
}

function targetButton(node: EventTarget | null): HTMLButtonElement | HTMLAnchorElement | null {
  if (!(node instanceof Element)) return null;
  return node.closest("button, a") as HTMLButtonElement | HTMLAnchorElement | null;
}

function handleClick(event: MouseEvent): void {
  const target = targetButton(event.target);
  if (!target) return;
  const label = normalizeLabel(target.textContent ?? target.getAttribute("aria-label") ?? "");
  if (!label) return;
  const shouldHandle = (fragments: string[]) => fragments.some((fragment) => label.includes(fragment));

  if (shouldHandle(["new task", "task nou", "create task"])) { event.preventDefault(); showTaskModal(); return; }
  if (shouldHandle(["new ticket", "ticket nou", "create ticket"])) { event.preventDefault(); showTicketModal(); return; }
  if (shouldHandle(["save view", "salvează view", "saved view"])) { event.preventDefault(); saveView(); return; }
  if (shouldHandle(["reset filter", "reset filtre", "clear filter"])) { event.preventDefault(); resetFilters(); return; }
  if (shouldHandle(["export"])) { event.preventDefault(); exportCsv(); return; }
  if (shouldHandle(["import"])) { event.preventDefault(); showImportModal(); return; }
  if (shouldHandle(["mark all read", "marchează toate"])) { event.preventDefault(); markRead(true); return; }
  if (shouldHandle(["mark read", "marchează citit"])) { event.preventDefault(); markRead(false); return; }
  if (shouldHandle(["open related", "deschide entitate"])) { event.preventDefault(); openRelatedEntity(); return; }
  if (shouldHandle(["add comment", "comentariu"])) { event.preventDefault(); addComment(); return; }
  if (shouldHandle(["add checklist", "checklist"])) { event.preventDefault(); addChecklist(); return; }
  if (shouldHandle(["add dependency", "dependency", "dependență"])) { event.preventDefault(); addDependency(); return; }
  if (shouldHandle(["attach file", "ataș", "fisier", "fișier"])) { event.preventDefault(); attachFile(); return; }
  if (shouldHandle(["start timer", "pornește timer"])) { event.preventDefault(); startTimer(); return; }
  if (shouldHandle(["stop timer", "oprește timer"])) { event.preventDefault(); stopTimer(); return; }
  if (shouldHandle(["approve", "aprobă"])) { event.preventDefault(); approveReject(true); return; }
  if (shouldHandle(["reject", "respinge"])) { event.preventDefault(); approveReject(false); return; }
  if (shouldHandle(["bulk", "selected", "selectate"])) { event.preventDefault(); bulkAction(); return; }
  if (shouldHandle(["viewer", "member", "manager", "super admin", "role"])) { event.preventDefault(); cycleRole(); }
}

function handleChange(event: Event): void {
  const target = event.target;
  if (!(target instanceof HTMLInputElement || target instanceof HTMLSelectElement)) return;
  const label = target.placeholder || target.name || target.getAttribute("aria-label") || "Filter";
  window.clearTimeout(Number(target.dataset.v171FilterTimer ?? "0"));
  const timer = window.setTimeout(() => {
    mutateState((draft) => addActivity(draft, `Filter/Search schimbat: ${label} = ${target.value || "empty"}`));
    toast("Filter/Search aplicat și înregistrat în activity log.", "info");
  }, 650);
  target.dataset.v171FilterTimer = String(timer);
}

function handleDrop(event: DragEvent): void {
  const section = routeSection();
  if (!section.includes("board")) return;
  event.preventDefault();
  mutateState((draft) => {
    const task = draft.tasks[0];
    if (task) {
      task.status = task.status === "Review" ? "Finalizat" : "Review";
      task.updatedAt = nowIso();
      addActivity(draft, `Board drag/drop mock: ${task.title} mutat în ${task.status}.`);
    }
  });
  toast("Board drag/drop interceptat: status schimbat și persistat.");
}

function prepareBoardDrag(): void {
  if (!routeSection().includes("board")) return;
  const candidates = Array.from(document.querySelectorAll("article, [class*=card], [class*=task], tr")) as HTMLElement[];
  candidates.slice(0, 12).forEach((item) => {
    if (!item.draggable) item.draggable = true;
    item.addEventListener("dragstart", (event) => {
      if (event.dataTransfer) event.dataTransfer.setData("text/plain", "v171-task");
    });
  });
}

export default function V171V15InPlaceFunctionalRuntime() {
  useEffect(() => {
    const state = loadState();
    document.body.setAttribute("data-v171-v15-functional-runtime-active", "true");
    document.body.setAttribute("data-v171-persistence", "REAL_LOCAL_PERSISTENT");
    renderSummary(state);
    prepareBoardDrag();
    document.addEventListener("click", handleClick, true);
    document.addEventListener("input", handleChange, true);
    document.addEventListener("change", handleChange, true);
    document.addEventListener("dragover", (event) => event.preventDefault());
    document.addEventListener("drop", handleDrop, true);
    const routeTimer = window.setInterval(prepareBoardDrag, 1500);
    return () => {
      window.clearInterval(routeTimer);
      document.removeEventListener("click", handleClick, true);
      document.removeEventListener("input", handleChange, true);
      document.removeEventListener("change", handleChange, true);
      document.removeEventListener("drop", handleDrop, true);
    };
  }, []);

  return (
    <div
      hidden
      data-v171-v15-functional-runtime="true"
      data-v171-mode="REAL_LOCAL_PERSISTENT"
      data-v171-goodday-functional-parity-on-v15="true"
    />
  );
}
