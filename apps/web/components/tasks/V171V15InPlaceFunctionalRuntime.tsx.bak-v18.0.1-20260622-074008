function loadState(): V171State {
  if (typeof window === "undefined") return seedState();
  const raw = window.localStorage.getItem(STORAGE_KEY);
  if (!raw) {
    const seeded = seedState();
    window.localStorage.setItem(STORAGE_KEY, JSON.stringify(seeded));
    return seeded;
  }
  try {
    const parsed = JSON.parse(raw) as V171State;
    return parsed.version === "17.1.0" ? parsed : seedState();
  } catch {
    const seeded = seedState();
    window.localStorage.setItem(STORAGE_KEY, JSON.stringify(seeded));
    return seeded;
  }
}

function saveState(state: V171State): void {
  window.localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
  window.dispatchEvent(new CustomEvent("servelect:v171-state", { detail: state }));
}

function mutateState(mutator: (state: V171State) => void): V171State {
  const state = loadState();
  mutator(state);
  saveState(state);
  renderSummary(state);
  return state;
}

function addActivity(state: V171State, message: string): void {
  state.activityLog.unshift({ id: makeId("act"), message, createdAt: nowIso() });
  state.activityLog = state.activityLog.slice(0, 80);
}

function notify(state: V171State, title: string, entityType: V171Notification["entityType"], entityId: string): void {
  state.notifications.unshift({ id: makeId("note"), title, entityType, entityId, read: false, createdAt: nowIso() });
}

function getToastRoot(): HTMLElement {
  let root = document.getElementById(TOAST_ID);
  if (!root) {
    root = document.createElement("div");
    root.id = TOAST_ID;
    root.setAttribute("data-v171-toast-root", "true");
    root.style.position = "fixed";
    root.style.right = "18px";
    root.style.bottom = "18px";
    root.style.zIndex = "99999";
    root.style.display = "grid";
    root.style.gap = "8px";
    root.style.maxWidth = "360px";
    document.body.appendChild(root);
  }
  return root;
}

function toast(message: string, tone: "success" | "error" | "info" = "success"): void {
  const root = getToastRoot();
  const item = document.createElement("div");
  item.setAttribute("data-v171-feedback", tone);
  item.textContent = message;
  item.style.padding = "10px 12px";
  item.style.borderRadius = "12px";
  item.style.border = tone === "error" ? "1px solid #fecaca" : "1px solid #bbf7d0";
  item.style.background = tone === "error" ? "#fef2f2" : "#ecfdf5";
  item.style.color = tone === "error" ? "#991b1b" : "#065f46";
  item.style.boxShadow = "0 18px 42px rgba(15, 23, 42, 0.14)";
  item.style.font = "13px Inter, system-ui, sans-serif";
  root.appendChild(item);
  window.setTimeout(() => item.remove(), 4200);
}

function clearModal(): void {
  document.getElementById(MODAL_ID)?.remove();
}

function createModal(title: string): HTMLDivElement {
  clearModal();
  const backdrop = document.createElement("div");
  backdrop.id = MODAL_ID;
  backdrop.setAttribute("data-v171-modal", "true");
  backdrop.style.position = "fixed";
  backdrop.style.inset = "0";
  backdrop.style.zIndex = "99998";
  backdrop.style.background = "rgba(15, 23, 42, 0.28)";
  backdrop.style.display = "grid";
  backdrop.style.placeItems = "center";
  const panel = document.createElement("div");
  panel.style.width = "min(680px, calc(100vw - 32px))";
  panel.style.background = "#ffffff";
  panel.style.border = "1px solid #dbe4ef";
  panel.style.borderRadius = "18px";
  panel.style.boxShadow = "0 28px 80px rgba(15,23,42,.28)";
  panel.style.padding = "18px";
  panel.style.font = "14px Inter, system-ui, sans-serif";
  const header = document.createElement("div");
  header.style.display = "flex";
  header.style.justifyContent = "space-between";
  header.style.alignItems = "center";
  header.style.marginBottom = "14px";
  const h = document.createElement("strong");
  h.textContent = title;
  h.style.fontSize = "18px";
  const x = document.createElement("button");
  x.type = "button";
  x.textContent = "Cancel";
  x.addEventListener("click", clearModal);
  x.style.border = "1px solid #dbe4ef";
  x.style.borderRadius = "10px";
  x.style.background = "#fff";
  x.style.padding = "8px 12px";
  header.append(h, x);
  panel.appendChild(header);
  backdrop.appendChild(panel);
  document.body.appendChild(backdrop);
  return panel;
}

function field(label: string, value = "", type = "text"): HTMLInputElement {
  const wrap = document.createElement("label");
  wrap.style.display = "grid";
  wrap.style.gap = "6px";
  wrap.style.color = "#475569";
  wrap.textContent = label;
  const input = document.createElement("input");
  input.type = type;
  input.value = value;
  input.style.border = "1px solid #dbe4ef";
  input.style.borderRadius = "10px";
  input.style.padding = "10px";
  input.style.color = "#0f172a";
  wrap.appendChild(input);
  return input;
}

function getRoute(): string {
  return window.location.pathname.replace(/\/$/, "") || "/taskuri";
}

function routeSection(): string {
  const route = getRoute();
  return route.split("/").filter(Boolean).pop() ?? "taskuri";
}

function renderSummary(state = loadState()): void {
  const root = document.querySelector("[data-v150-goodday-structural-parity]") as HTMLElement | null;
  if (!root) return;
  let summary = document.getElementById(SUMMARY_ID) as HTMLElement | null;
  if (!summary) {
    summary = document.createElement("div");
    summary.id = SUMMARY_ID;
    summary.setAttribute("data-v171-v15-in-place-summary", "true");
    summary.style.position = "fixed";
    summary.style.left = "calc(50% - 220px)";
    summary.style.bottom = "14px";
    summary.style.zIndex = "9999";
    summary.style.display = "flex";
    summary.style.gap = "10px";
    summary.style.alignItems = "center";
    summary.style.padding = "8px 12px";
    summary.style.border = "1px solid #bbf7d0";
    summary.style.background = "rgba(236, 253, 245, .96)";
    summary.style.borderRadius = "999px";
    summary.style.boxShadow = "0 14px 36px rgba(15, 23, 42, .12)";
    summary.style.font = "12px Inter, system-ui, sans-serif";
    summary.style.color = "#065f46";
    document.body.appendChild(summary);
  }
  const unread = state.notifications.filter((note) => !note.read).length;
  const running = state.activeTimerTaskId ? "timer pornit" : "timer oprit";
  summary.innerHTML = `<strong>V15 functional layer</strong><span>${state.tasks.length} taskuri</span><span>${state.tickets.length} tickets</span><span>${unread} unread</span><span>${state.savedViews.length} saved views</span><span>${running}</span>`;
}

