"use client";

import { useEffect } from "react";

type V171Status = "Backlog" | "Planificat" | "In lucru" | "Review" | "Finalizat" | "Blocat";
type V171Priority = "Low" | "Medium" | "High" | "Critical";
type V171Severity = "Low" | "Medium" | "High" | "Critical";
type V171Role = "Viewer" | "Member" | "Manager" | "Super Admin";

type V171Task = {
  id: string;
  title: string;
  project: string;
  department: string;
  assignee: string;
  status: V171Status;
  priority: V171Priority;
  dueDate: string;
  estimateHours: number;
  trackedHours: number;
  comments: number;
  checklist: string[];
  dependencies: string[];
  attachments: string[];
  createdAt: string;
  updatedAt: string;
};

type V171Ticket = {
  id: string;
  title: string;
  severity: V171Severity;
  assignee: string;
  status: V171Status;
  comments: number;
  attachments: string[];
  convertedTaskId?: string;
  createdAt: string;
  updatedAt: string;
};

type V171Notification = {
  id: string;
  title: string;
  entityType: "task" | "ticket" | "approval" | "view" | "import";
  entityId: string;
  read: boolean;
  createdAt: string;
};

type V171SavedView = {
  id: string;
  title: string;
  path: string;
  query: string;
  density: string;
  statusFilter: string;
  assigneeFilter: string;
  createdAt: string;
};

type V171Approval = {
  id: string;
  title: string;
  entityId: string;
  status: "Pending" | "Approved" | "Rejected";
  reason?: string;
  updatedAt: string;
};

type V171TimeEntry = {
  id: string;
  taskId: string;
  startedAt: string;
  stoppedAt?: string;
  hours?: number;
};

type V171Activity = {
  id: string;
  message: string;
  createdAt: string;
};

type V171State = {
  version: "17.1.0";
  role: V171Role;
  tasks: V171Task[];
  tickets: V171Ticket[];
  notifications: V171Notification[];
  savedViews: V171SavedView[];
  approvals: V171Approval[];
  timeEntries: V171TimeEntry[];
  activityLog: V171Activity[];
  activeTimerTaskId?: string;
};

