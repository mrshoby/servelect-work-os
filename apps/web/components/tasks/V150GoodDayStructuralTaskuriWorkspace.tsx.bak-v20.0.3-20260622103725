function resolveFamily(routeKey: string): PageFamily {
  const key = routeKey.toLowerCase();
  if (key === "" || key === "taskuri" || key.includes("overview")) return "overview";
  if (key.includes("my-work") || key.includes("action-required") || key.includes("focus")) return "my-work";
  if (key.includes("inbox") || key.includes("notification") || key.includes("updates") || key.includes("activity")) return "inbox";
  if (key.includes("ticket") || key.includes("request")) return "tickets";
  if (key.includes("proiecte-active")) return "active-projects";
  if (key.includes("proiecte-viitoare")) return "future-projects";
  if (key.includes("proiecte-finalizate")) return "completed-projects";
  if (key.includes("board") || key.includes("kanban") || key.includes("bulk")) return "board";
  if (key.includes("tabel") || key.includes("table")) return "table";
  if (key.includes("calendar") && !key.includes("gantt")) return "calendar";
  if (key.includes("gantt") || key.includes("timeline") || key.includes("dependency")) return "gantt";
  if (key.includes("workload") || key.includes("capacity") || key.includes("resource")) return "workload";
  if (key.includes("report") || key.includes("executive")) return "reports";
  if (key.includes("automation") || key.includes("workflow") || key.includes("command")) return "automations";
  if (key.includes("forms") || key.includes("intake") || key.includes("portal")) return "forms";
  if (key.includes("time") || key.includes("timesheet")) return "timesheets";
  if (key.includes("provider") || key.includes("webhook") || key.includes("mutation") || key.includes("ledger") || key.includes("replay")) return "provider";
  if (key.includes("approval") || key.includes("sla") || key.includes("decision") || key.includes("rbac")) return "approvals";
  if (key.includes("files") || key.includes("evidence") || key.includes("document")) return "files";
  if (key.includes("project") || key.includes("program") || key.includes("portfolio") || key.includes("workgraph")) return "active-projects";
  return "default";
}

