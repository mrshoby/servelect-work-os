type Notification = { id: string; title: string; kind: string; relatedId: string; read: boolean; archived: boolean; scheduled?: string; severity: Priority };
type Approval = { id: string; title: string; project: string; owner: string; status: "Pending" | "Approved" | "Rejected"; impact: string };
type TimeEntry = { id: string; taskId: string; user: string; hours: number; date: string; running?: boolean };
type Comment = { id: string; author: string; text: string; date: string };
type Activity = { id: string; actor: string; text: string; date: string };
type SavedView = { id: string; name: string; family: PageFamily; filters: string; density: "compact" | "comfortable" };
type Automation = { id: string; name: string; trigger: string; action: string; enabled: boolean; runs: number };
type Store = { tasks: Task[]; tickets: Ticket[]; projects: Project[]; users: User[]; notifications: Notification[]; approvals: Approval[]; timeEntries: TimeEntry[]; savedViews: SavedView[]; automations: Automation[]; requests: string[] };

