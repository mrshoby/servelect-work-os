  assignee: string; owner: string; startDate: string; dueDate: string; estimate: number; tracked: number; progress: number; tags: string[];
  checklist: { id: string; title: string; done: boolean }[]; comments: Comment[]; activity: Activity[]; attachments: string[]; dependencies: string[];
